)

$TZInfo = Get-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Control\TimeZoneInformation"

$UserTime = $TZInfo.TimeZoneKeyName
$UserBias = -$TZInfo.ActiveTimeBias

$Bam = foreach ($Sid in $Users | Select-Object -Unique) {

    foreach ($rp in $rpath) {

        $FullPath = "$($rp)UserSettings\$Sid"

        Write-Host -ForegroundColor Red "Extracting " -NoNewLine
        Write-Host -ForegroundColor Blue $FullPath

        try {
            $RegObj = Get-ItemProperty -Path $FullPath -ErrorAction SilentlyContinue
            $BamItems = $RegObj.PSObject.Properties.Name
        }
        catch {
            continue
        }

        try {
            $objSID = New-Object System.Security.Principal.SecurityIdentifier($Sid)
            $User = $objSID.Translate([System.Security.Principal.NTAccount]).Value
        }
        catch {
            $User = ""
        }

        foreach ($Item in $BamItems) {

            try {
                $Key = $RegObj.$Item

                if ($Key.Length -ne 24) {
                    continue
                }

                $Hex = [System.BitConverter]::ToString($Key[7..0]) -replace "-", ""
                $FileTime = [Convert]::ToInt64($Hex, 16)

                $TimeUTC = [DateTime]::FromFileTimeUtc($FileTime)
                $TimeLocal = [DateTime]::FromFileTime($FileTime)
                $TimeUser = $TimeUTC.AddMinutes($UserBias)

                $path = ""
