                    'Last Execution User Time'  = $TimeUser.ToString("yyyy-MM-dd HH:mm:ss")
                    Application                 = $f
                    Path                        = $path
                    Signature                   = $sig
                    User                        = $User
                    SID                         = $Sid
                    RegPath                     = $rp
                }

            }
            catch {
                continue
            }
        }
    }
}

